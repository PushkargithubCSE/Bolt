{
    "manifest_version": 3,
    "name": "ChatGPT Speed Optimizer",
    "version": "1.0",
    "description": "Improves ChatGPT performance by collapsing old messages.",
    "permissions": ["activeTab"],
    "content_scripts": [
      {
        "matches": [
          "https://chat.openai.com/*",
          "https://chatgpt.com/*"
        ],
        "js": ["content.js"],
        "css": ["style.css"]
      }
    ]
  }

  